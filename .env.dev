# Linux Dev Server Environment Configuration
# Linux dev 서버 환경 설정입니다.
# docker run --env-file .env.dev ...
# 또는 build 시: ./build.sh ... --env dev

# 애플리케이션 설정
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002

# LLM 설정 (dev vLLM 서버)
CALL_TYPE=vllm
LLM_URL=http://vllm-dev:8000
LLM_AUTH_HEADER=
MODEL_PATH=qwen/qwen-7b-chat

# LLM 설정 (Agent) - CALL_TYPE=agent 일 때 사용
AGENT_NAME=

# SFTP 설정 (dev 서버)
SFTP_HOST=sftp-dev.internal
SFTP_PORT=22
SFTP_USERNAME=dev_user
SFTP_PASSWORD=dev_password
SFTP_KEY=
SFTP_ROOT_PATH=/data

# 콜백 설정 (dev 콜백 서버)
CALLBACK_URL=http://callback-dev:3000/callback
CALLBACK_AUTH_HEADER=

# 템플릿 설정
TEMPLATE_NAME=qwen_default

# 배치 처리 설정
BATCH_CONCURRENCY=4

# 로깅 설정
LOG_LEVEL=INFO

