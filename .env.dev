# Development Environment Configuration
# 개발 환경에서 사용하는 설정입니다.
# 로컬 테스트: .env.dev를 .env로 복사하여 사용
# Docker 개발: docker run --env-file .env.dev ...

# 애플리케이션 설정
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002

# LLM 설정 (vLLM)
CALL_TYPE=vllm
LLM_URL=http://localhost:8000
LLM_AUTH_HEADER=
MODEL_PATH=qwen/qwen-7b-chat

# LLM 설정 (Agent) - CALL_TYPE=agent 일 때 사용
AGENT_NAME=

# SFTP 설정
SFTP_HOST=localhost
SFTP_PORT=22
SFTP_USERNAME=demo
SFTP_PASSWORD=password
SFTP_KEY=
SFTP_ROOT_PATH=/

# 콜백 설정
CALLBACK_URL=http://localhost:8002/mock/callback
CALLBACK_AUTH_HEADER=

# 템플릿 설정
TEMPLATE_NAME=qwen_default

# 배치 처리 설정
BATCH_CONCURRENCY=2

# 로깅 설정
LOG_LEVEL=DEBUG
