# Production Environment Configuration
# 프로덕션 환경에서 사용하는 설정입니다.
# Docker 운영: docker run --env-file .env.prod ...

# 애플리케이션 설정
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8002

# LLM 설정 (vLLM)
CALL_TYPE=vllm
LLM_URL=http://vllm-server:8000
LLM_AUTH_HEADER=Bearer new1234!
MODEL_PATH=/model/qwen-30b

# LLM 설정 (Agent) - CALL_TYPE=agent 일 때 사용
AGENT_NAME=

# SFTP 설정
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=recsttna
SFTP_PASSWORD=gksxn1q2w#E$R
SFTP_KEY=
SFTP_ROOT_PATH=/TWA2/jba/STT

# 콜백 설정
CALLBACK_URL=http://callback-server:3000/callback
CALLBACK_AUTH_HEADER=Bearer callback-token

# 템플릿 설정
TEMPLATE_NAME=qwen_default

# 배치 처리 설정
BATCH_CONCURRENCY=8

# 로깅 설정
LOG_LEVEL=INFO
